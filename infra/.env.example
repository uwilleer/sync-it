# ============================================================ #
#   REQUIRED SECRETS                                             #
# ============================================================ #
# Эти переменные ОБЯЗАТЕЛЬНЫ — сервисы не стартуют без них.
# Всё остальное имеет defaults в коде/compose; добавляй только
# то, что нужно override'нуть.

# -------- DATABASE -------- #
DATABASE_PASSWORD=
POSTGRES_PASSWORD="${DATABASE_PASSWORD}"
PGBOUNCER_PASSWORD="${DATABASE_PASSWORD}"

# ------ API GATEWAY ------ #
API_GATEWAY_API_KEY=

# -------- GPT API -------- #
GPT_API_OPENAI_API_KEY=

# ------ SCRAPER API ------ #
SCRAPER_API_TELETHON_API_ID=
SCRAPER_API_TELETHON_API_HASH=
SCRAPER_API_TELETHON_SESSION_STRING=

# ----- TELEGRAM BOT ------ #
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_SUPPORT_USERNAME=
# Только если TELEGRAM_BOT_USE_WEBHOOK=true:
# TELEGRAM_BOT_WEBHOOK_URL=https://example.com/webhook
# TELEGRAM_BOT_WEBHOOK_API_KEY=

# --------- CADDY --------- #
# Обязательны, если поднимается caddy (reverse proxy + Let's Encrypt).
# CADDY_DOMAIN=syncit.tech
# ACME_EMAIL=ops@example.com

# --------- SHARED --------- #
SHARED_CLIENT_HEAD_HUNTER_CLIENT_ID=
SHARED_CLIENT_HEAD_HUNTER_CLIENT_SECRET=
SHARED_CLIENT_HEAD_HUNTER_ACCESS_TOKEN=
SHARED_CLIENT_HEAD_HUNTER_EMAIL=

# --------- SENTRY --------- #
# Только если SENTRY_ENABLED=true:
# SENTRY_DSN_URL=https://<key>@sentry.io/<project>


# ============================================================ #
#   OPTIONAL OVERRIDES (defaults в BaseSettings / compose)       #
# ============================================================ #
# Раскомментируй только если надо поменять дефолт.
#
# ENV_MODE=production                    # development / production
# ENV_PROJECT_NAME=syncit
# ENV_DOCKER_USERNAME=diplomatgmg
# ENV_SERVICE_INTERNAL_HOST=0.0.0.0
# ENV_SERVICE_INTERNAL_PORT=8000
#
# LOG_LEVEL=INFO                         # DEBUG / INFO / WARNING / ERROR
#
# SENTRY_ENABLED=false
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1
# SENTRY_PROFILE_LIFECYCLE=trace         # manual / trace
# SENTRY_SLOW_SQL_THRESHOLD=1.0
#
# DATABASE_HOST=pgbouncer
# DATABASE_PORT=6432
# DATABASE_DB=syncit
# DATABASE_USER=syncit
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB="${DATABASE_DB}"
# POSTGRES_USER="${DATABASE_USER}"
# PGBOUNCER_HOST=pgbouncer
# PGBOUNCER_PORT=6432
# PGBOUNCER_DB="${DATABASE_DB}"
# PGBOUNCER_USER="${DATABASE_USER}"
# PGBOUNCER_MAX_CLIENT_CONN=1000
#
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_CACHE_DB=0
# REDIS_CELERY_BROKER_DB=1
# REDIS_CELERY_RESULT_DB=2
# REDIS_BOT_DB=3
#
# API_GATEWAY_HOST=0.0.0.0
# API_GATEWAY_PORT=8000
# GPT_API_PORT=8001
# GPT_API_OPENAI_PROXY=http://host:port
# GPT_API_OPENAI_MODEL=gpt-5-nano
# SCRAPER_API_PORT=8002
# VACANCY_PARSER_PORT=8003
# VACANCY_PROCESSOR_PORT=8004
# TELEGRAM_BOT_PORT=8005
# VACANCY_MATCHER_PORT=8006
#
# TELEGRAM_BOT_RATE_LIMIT=0.5
# TELEGRAM_BOT_USE_WEBHOOK=false
# TELEGRAM_BOT_STATE_TTL=600             # 10 min
# TELEGRAM_BOT_DATA_TTL=86400            # 1 day
#
# SHARED_CLIENT_HEAD_HUNTER_APP_NAME=syncit

# -------- DOCKER paths (compose-only) -------- #
# Эти переменные нужны только docker-compose (пути относительно compose-файлов).
# Defaults в compose: ../../.. и ../..
# SERVICE_PROJECT_ROOT=../../..
# MAIN_COMPOSE_PROJECT_ROOT=../..
